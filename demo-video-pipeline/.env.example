# ─────────────────────────────────────────────────────────────
# demo-video-pipeline — environment configuration (EXAMPLE)
# Copy to .env and adjust. .env is gitignored — never commit real values.
# ─────────────────────────────────────────────────────────────

# AWS region for Amazon Polly and/or the Amazon SageMaker endpoint.
AWS_REGION=us-east-1

# AWS profile (named profile / SSO / Isengard). Leave blank for the default chain.
AWS_PROFILE=

# ── TTS backend: polly | qwen-speaker | qwen-clone ──────────────
TTS_BACKEND=polly

# Amazon Polly (backend = polly): any neural voice (Matthew, Joanna, Stephen, Ruth, ...).
POLLY_VOICE=Matthew
POLLY_ENGINE=neural

# Qwen (backend = qwen-speaker / qwen-clone): Amazon SageMaker async endpoint.
QWEN_SPEAKER=Aiden
QWEN_INSTRUCT=calm, clear, professional narration

# ── Amazon SageMaker deploy (only for the qwen-* backends) ──────
# Leave blank to auto-create. S3_BUCKET defaults to sagemaker-qwen3-tts-<account>-<region>.
S3_BUCKET=
SAGEMAKER_ROLE_ARN=
ENDPOINT_NAME=qwen3-tts-async
INSTANCE_TYPE=ml.g5.xlarge
PROJECT_TAG=demo-video-pipeline

# Public, Apache-2.0 Qwen3-TTS model ids (no HuggingFace token required).
HF_MODEL_CUSTOM_VOICE=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
HF_MODEL_BASE=Qwen/Qwen3-TTS-12Hz-1.7B-Base
